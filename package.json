{
  "name": "@palpateam/n8n-nodes-zoho-analytics",
  "version": "1.0.2",
  "description": "Community n8n node for Zoho Analytics API v2",
  "keywords": [
    "n8n-community-node-package",
    "n8n-node",
    "zoho",
    "zoho-analytics"
  ],
  "author": {
    "name": "Palpateam"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/palpateam/n8n-nodes-zoho-analytics.git"
  },
  "homepage": "https://github.com/palpateam/n8n-nodes-zoho-analytics#readme",
  "bugs": {
    "url": "https://github.com/palpateam/n8n-nodes-zoho-analytics/issues"
  },
  "license": "MIT",
  "main": "index.js",
  "scripts": {
    "build": "tsc && gulp build:icons",
    "dev": "tsc --watch",
    "format": "prettier nodes credentials --write",
    "lint": "eslint nodes credentials package.json",
    "lintfix": "eslint nodes credentials package.json --fix"
  },
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/ZohoAnalyticsOAuth2Api.credentials.js"
    ],
    "nodes": [
      "dist/nodes/ZohoAnalytics/ZohoAnalytics.node.js"
    ]
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  },
  "devDependencies": {
    "@types/node": "^16.0.0",
    "@typescript-eslint/parser": "^5.29.0",
    "eslint-plugin-n8n-nodes-base": "^1.11.0",
    "gulp": "^4.0.2",
    "n8n-workflow": "^1.20.0",
    "prettier": "^2.7.1",
    "typescript": "^5.9.3"
  }
}
